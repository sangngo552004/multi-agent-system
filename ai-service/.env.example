# --- Extraction Strategy ---
EXTRACTION_STRATEGY=hybrid

# ── NER Model ──
NER_EXTRACTOR_TYPE=gliner
GLINER_MODEL_NAME=urchade/gliner_medium-v2.1
NER_MODEL_NAME=yashpwr/resume-ner-bert-v2
CONFIDENCE_THRESHOLD=0.6

# ── File Validation ──
MAX_FILE_SIZE_MB=10
MAX_PAGE_COUNT=10

# ── LLM Fallback (Google Gemini) ──
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL_NAME=gemini-3.5-flash
LLM_DAILY_RATE_LIMIT=100

# ── Career Path Agent ──
CAREER_PATH_ENABLED=false
CAREER_PATH_TIMEOUT_SECONDS=45
CAREER_PATH_MAX_RETRIES=1
CAREER_PATH_TEMPERATURE=0.2

# ── RabbitMQ ──
RABBITMQ_URL=amqp://your_user:your_password@localhost:5672/
RABBITMQ_ENABLED=false

# ── Server ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── OCR ──
TESSERACT_LANG=eng+vie
